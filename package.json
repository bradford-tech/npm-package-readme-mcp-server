{
  "name": "@bradford-tech/npm-package-readme-mcp-server",
  "version": "0.1.4",
  "description": "MCP server for fetching npm package README and usage information",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "npm-package-readme-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bradford-tech/npm-package-readme-mcp-server.git"
  },
  "homepage": "https://github.com/bradford-tech/npm-package-readme-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/bradford-tech/npm-package-readme-mcp-server/issues"
  },
  "keywords": [
    "mcp",
    "npm",
    "readme",
    "package",
    "documentation"
  ],
  "author": "sbs44",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
